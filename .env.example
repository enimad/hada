NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics/session replay (optionnel en local, requis pour tracker en prod)
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest

# Chat v2: Google sert de fournisseur primaire pour l'analyse d'intention.
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Optionnel : agent Mistral dedie a la normalisation des fiches prestataires.
# Des valeurs par defaut existent dans le code.
MISTRAL_VENDOR_PROFILE_AGENT_ID=
MISTRAL_VENDOR_PROFILE_AGENT_VERSION=

# Decap CMS / GitHub OAuth pour /admin
DECAP_GITHUB_CLIENT_ID=
DECAP_GITHUB_CLIENT_SECRET=

# Firecrawl
FIRECRAWL_API_KEY=
# Optionnel : coller plusieurs clés séparées par des virgules, points-virgules ou retours ligne.
FIRECRAWL_API_KEYS=
# Optionnel : libelles internes pour le script de suivi des credits.
FIRECRAWL_API_KEY_EMAILS=

# Survey notifications (optionnel, active l'envoi email automatique)
RESEND_API_KEY=
SURVEY_NOTIFY_TO=
SURVEY_NOTIFY_FROM=
